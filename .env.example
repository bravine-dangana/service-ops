# SQLite database file used by Prisma. Relative paths here are resolved from
# the prisma/ folder itself (where schema.prisma lives), not the project root
# — so "./dev.db" correctly means prisma/dev.db. Do NOT prefix with "./prisma/".
DATABASE_URL="file:./dev.db"

# Random secret NextAuth uses to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Must match the URL the app is actually served at.
NEXTAUTH_URL="http://localhost:3000"

# The first person to sign up with this email is automatically made an admin.
# Every other sign-up starts as "viewer" until an existing admin promotes them
# from /admin/users. Leave unset to require manual promotion for everyone.
INITIAL_ADMIN_EMAIL="you@cellulant.io"
